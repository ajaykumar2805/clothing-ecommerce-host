# Server Configuration
PORT=5000
NODE_ENV=development

# Authentication
JWT_SECRET=clothing_ecommerce_secret_key_2026

# Database Configuration (Docker Compose Defaults)
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clothing_ecommerce

# Alternatively, set the full connection URI directly:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/clothing_ecommerce

# Stripe API Keys (Test Mode)
# Leave blank or mock to bypass and test with mock payment simulation
STRIPE_SECRET_KEY=your_stripe_secret_key_here
